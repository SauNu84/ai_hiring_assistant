ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Comma-separated list of allowed CORS origins (production: set to your Vercel URL)
# Example: https://your-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# Frontend — set to Railway backend URL in production
# Example: https://your-backend.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
